# Copy to `.env` and fill in. `.env` is gitignored.
#
# Supabase Postgres connection string (same project the NCAAF feeder writes to).
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the direct connection or session pooler URI.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Token gating the web app's /api/revalidate cache-purge endpoint. The build scripts
# send it; the web app checks it. Set the SAME value in web/.env.local. If unset, the
# web endpoint skips the check (fine for local dev).
RECOMPUTE_TOKEN=change_me

# Where the running Next.js app is, so the build scripts can ping /api/revalidate to
# purge cached reads when a rebuild finishes. Match your dev port (often 3001) or the
# deployed URL. If unreachable, the cache just falls back to its 1-day TTL.
WEB_BASE_URL=http://localhost:3000

# NOTE: the Next.js app (web/) has its own env file: web/.env.local — it needs
#   SUPABASE_DB_URL=...   (same connection string as above)
#   RECOMPUTE_TOKEN=...   (same token, so /api/revalidate accepts the build pings)
